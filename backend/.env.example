# Database
DATABASE_URL=postgresql://postgres:your-db-password@db.gqezmqopvjvpdnknmfap.supabase.co:5432/postgres

# Supabase Storage
SUPABASE_URL=https://gqezmqopvjvpdnknmfap.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET=documents

# LLM
ANTHROPIC_API_KEY=your-api-key-here
LLM_PROVIDER=stub  # stub | claude

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://127.0.0.1:3000,https://jokari-knowledge-hub.vercel.app

# Trusted external ingestion
TRUSTED_INGESTION_API_KEYS=pim-service:change-me
TRUSTED_PIM_INGESTION_SOURCES=pim-service
WEBSITE_IMPORT_ALLOWED_HOSTS=jokari.de,www.jokari.de,jostudy.de,www.jostudy.de
WEBSITE_IMPORT_MAX_PAGES=50
WEBSITE_IMPORT_MAX_IMAGES_PER_PAGE=8
WEBSITE_IMPORT_HTTP_TIMEOUT_SECONDS=10

# App
DEBUG=false
SECRET_KEY=your-secret-key-change-in-production
